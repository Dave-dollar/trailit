# TrailIt data source
# Keep mock/localStorage mode for current development and until Supabase RLS is ready.
TRAILIT_DATA_MODE=mock
TRAILIT_ENABLE_DATA_MODE_TOGGLE=false

# Future Vite/Node build placeholders.
# Use a Supabase publishable key in browser code. Never expose a secret or service-role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
VITE_SUPABASE_PHOTO_BUCKET=trail-photos
